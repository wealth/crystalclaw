FROM ubuntu:24.04 AS downloader

ARG RELEASE_TAG=main-b4466-d07d4c7
# avx2 is the most compatible; use avx512/avx512_vnni/etc. for newer CPUs
ARG AVX_LEVEL=avx2

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl unzip ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN curl -fSL \
    "https://github.com/Thireus/ik_llama.cpp/releases/download/${RELEASE_TAG}/ik_llama-${RELEASE_TAG}-bin-ubuntu-x64-${AVX_LEVEL}.zip" \
    -o /tmp/ik_llama.zip && \
    unzip /tmp/ik_llama.zip -d /tmp/ik_llama && \
    echo "=== zip contents ===" && find /tmp/ik_llama -type f && \
    BIN_DIR=$(find /tmp/ik_llama -type f -name '*server*' | head -1 | xargs dirname) && \
    cp "$BIN_DIR"/*.so* /usr/local/lib/ 2>/dev/null || true && \
    cp "$BIN_DIR"/llama-server /usr/local/bin/llama-server && \
    chmod +x /usr/local/bin/llama-server

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

COPY --from=downloader /usr/local/lib/ /usr/local/lib/
COPY --from=downloader /usr/local/bin/llama-server /usr/local/bin/llama-server
RUN ldconfig

RUN printf '#!/bin/sh\nset -e\nMODEL_FILE="/models/${HF_FILE}"\nif [ ! -f "$MODEL_FILE" ]; then\n  echo "Downloading ${HF_FILE} from ${HF_REPO}..."\n  mkdir -p /models\n  curl -fSL "https://huggingface.co/${HF_REPO}/resolve/main/${HF_FILE}" -o "$MODEL_FILE"\n  echo "Download complete."\nfi\nexec llama-server --model "$MODEL_FILE" --host "${HOST}" --port "${PORT}" --ctx-size "${CTX_SIZE}" --n-gpu-layers "${N_GPU_LAYERS}" --jinja\n' > /entrypoint.sh && chmod +x /entrypoint.sh

ENV HF_REPO=lmstudio-community/Qwen3.5-4B-GGUF
ENV HF_FILE=Qwen3.5-4B-Q4_K_M.gguf
ENV HOST=0.0.0.0
ENV PORT=8080
ENV CTX_SIZE=4096
ENV N_GPU_LAYERS=0

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=600s --retries=5 \
    CMD curl -sf http://localhost:8080/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
